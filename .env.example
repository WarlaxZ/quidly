# Database (SQLite file)
DATABASE_URL="file:./dev.db"

# Auth — generate AUTH_USERNAME and AUTH_PASSWORD_HASH with:  npm run set-password
# NOTE: in a .env file the hash's $ characters must be backslash-escaped (\$argon2id\$...);
# the set-password command prints the correctly-escaped line. For real env vars
# (Docker/systemd) use the UNescaped hash.
AUTH_USERNAME=
AUTH_PASSWORD_HASH=
# A long random secret (32+ chars), e.g. from:  openssl rand -base64 32
SESSION_SECRET=

# AI receipt scanning (optional) — set to enable the Scan feature. Uses YOUR Anthropic key (~pennies/receipt).
ANTHROPIC_API_KEY=
# Vision model for extraction (optional; defaults to a cheap vision-capable Claude model)
EXTRACTION_MODEL=
# Where uploaded receipts are stored (optional; mount as a persistent volume in production)
UPLOAD_DIR=./uploads
